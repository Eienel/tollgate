# Tollgate (x402-merchant) configuration for Pharos Atlantic Testnet.
# Copy to .env and fill in. Never commit a real private key.

# ---------------------------------------------------------------------------
# Network. Pick a preset, or override any field below.
#   atlantic = Pharos Atlantic Testnet (chain id 688689), the default.
#   mainnet  = Pharos Pacific Mainnet (chain id 1672).
# On mainnet you must set TOLLGATE_USDC_ADDRESS; there is no verified default.
# ---------------------------------------------------------------------------
TOLLGATE_NETWORK=atlantic
# These override the preset if set. Leave blank to use the preset defaults.
TOLLGATE_CHAIN_ID=
TOLLGATE_RPC_URL=
TOLLGATE_WSS_URL=
TOLLGATE_EXPLORER_URL=

# Test USDC on Atlantic. Verified plain ERC-20 (6 decimals), no EIP-3009.
# See DECISION.md and `npm run step0`. Replace if Pharos ships an official token.
TOLLGATE_USDC_ADDRESS=0xE0BE08c77f415F577A1B3A9aD7a1Df1479564ec8

# ---------------------------------------------------------------------------
# Identity. The private key is read here and redacted from all logs and errors.
# The merchant uses payTo to receive. The buyer and facilitator use the key.
# ---------------------------------------------------------------------------
# Hex private key, with or without 0x. Required for buyer payments and live settle.
TOLLGATE_PRIVATE_KEY=
# Address that receives merchant payments. Defaults to the key's address if unset.
TOLLGATE_PAY_TO=

# ---------------------------------------------------------------------------
# Reliability and safety rails.
# ---------------------------------------------------------------------------
# Where the persistent idempotency log and receipts ledger live.
TOLLGATE_DATA_DIR=./.tollgate
# Secret used to sign receipts and session tokens (HMAC-SHA256). Set a long random value.
TOLLGATE_SIGNING_SECRET=change-me-to-a-long-random-string
# Session token lifetime in seconds.
TOLLGATE_TOKEN_TTL_SECONDS=900
# Simulate without broadcasting any transaction. true or false.
TOLLGATE_DRY_RUN=false
# Require buyers to sign their claim (tollgate-claim:<txHash>) with the paying
# key, so an observer cannot steal a tx hash off the chain and claim it first.
# Signatures are always checked when present; set true to make them mandatory.
TOLLGATE_REQUIRE_CLAIM_SIGNATURE=false

# Buyer spend caps, in whole USDC. Reject payments above these.
TOLLGATE_MAX_PER_TX_USDC=5
TOLLGATE_MAX_PER_SESSION_USDC=25

# ---------------------------------------------------------------------------
# Transport.
# ---------------------------------------------------------------------------
# MCP transport: stdio (default) or http.
TOLLGATE_TRANSPORT=stdio
# Port for http MCP transport and for the demo dashboard.
TOLLGATE_HTTP_PORT=8402
TOLLGATE_DASHBOARD_PORT=8088
